# Variáveis de Ambiente — EXEMPLO
# Copie este arquivo para .env e preencha com seus valores reais.
# ⚠️ NUNCA commitar o arquivo .env com valores reais.

# ─── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=newsletter_db
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/newsletter_db"

# ─── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Autenticação JWT ─────────────────────────────────────────────
JWT_SECRET=mude-esta-chave-em-producao-use-uma-string-longa-e-aleatoria
JWT_EXPIRES_IN=7d

# ─── Google Gemini AI ─────────────────────────────────────────────
# Obtenha sua chave gratuita em: https://aistudio.google.com
GEMINI_API_KEY=<CHAVE_DE_API>

# ─── App ──────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
